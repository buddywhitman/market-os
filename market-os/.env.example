# Copy to .env and fill in. All optional for `make demo` (runs fully offline).
POSTGRES_DSN=postgresql://marketos:marketos@localhost:5432/marketos
REDIS_URL=redis://localhost:6379/0
# Low-cost / free data APIs
FRED_API_KEY=
FMP_API_KEY=
NEWSAPI_KEY=
# LLM / RAG (sentiment agent) — optional
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
CODE_VERSION=0.1.0

# AngelOne SmartAPI (india sleeve data + order placement) — see
# src/marketos/data/fetchers/angelone_fetcher.py for setup instructions
ANGELONE_API_KEY=
ANGELONE_CLIENT_CODE=
ANGELONE_MPIN=
ANGELONE_TOTP_SECRET=

# Telegram (Phase 5 briefings) — see src/marketos/notify/telegram.py for setup instructions
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
